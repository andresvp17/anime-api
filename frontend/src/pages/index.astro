---
import Form from "../components/form.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.27.0/themes/prism.min.css"
			rel="stylesheet"
		/>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>A(PI)NIME</title>
	</head>
	<body>
		<main>
			<h1 class="title">A(PI)NIME</h1>
			<Form />
			<pre class="json_viewer" id="list"></pre>
		</main>
	</body>
</html>

<style>
	:root {
		--rounded: 15px;
		--primary: #d55f8a;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	main {
		max-width: 55rem;
		margin: 0 auto;
	}

	body {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			"Open Sans",
			"Helvetica Neue",
			sans-serif;
	}

	.title {
		font-size: 5rem;
		text-align: center;
		color: #d55f8a;
		margin-top: 3rem;
		margin-bottom: 6rem;
		transform: skewY(-10deg);
		text-shadow: 0 0 5px#a22e4f;
	}

	pre {
		font-family: monospace;
		max-height: 38rem;
		overflow-y: scroll;
		overflow-x: scroll;
		background-color: aliceblue;
		padding: 1.5rem;
	}

	.json_viewer pre span.string {
		color: #008000; /* Green */
	}

	.json_viewer pre span.number {
		color: #ff4500; /* Orange */
	}

	.json_viewer pre span.boolean {
		color: #006400; /* Dark green */
	}

	@media (max-width: 500px) {
		.title {
			font-size: 4rem;
		}
	}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.27.0/prism.min.js"
></script>
